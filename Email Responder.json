    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const rawText = item.json.output || \"{}\";\n\n  let parsed;\n  try {\n    parsed = JSON.parse(rawText);\n  } catch (e) {\n    parsed = {\n      isReview: false,\n      sentiment: \"Neutral\",\n      reply: \"\",\n      customerEmail: \"\"\n    };\n  }\n\n  return {\n    json: {\n      customerName: parsed.customerName || item.json.customerName || \"\",\n      customerEmail: parsed.customerEmail || item.json.customerEmail || \"\",\n\n      reviewText: item.json.original?.reviewText || \"\",\n      subject: item.json.original?.subject || \"\",\n      timestamp: item.json.original?.timestamp || \"\",\n\n      isReview: parsed.isReview === true,\n      sentiment: parsed.sentiment || \"Neutral\",\n      aiReply: parsed.reply || \"\"\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        816,
        128
      ],
      "id": "8bd6b3ed-3cd5-4078-97cc-22b40941990a",
      "name": "Parser"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const fromData = item.json.from?.value?.[0] || {};\n\n  const customerEmail = fromData.address || \"\";\n  const customerName = fromData.name || customerEmail;\n\n  return {\n    json: {\n      customerName,\n      customerEmail,\n      reviewText: item.json.text || \"\",\n      subject: item.json.subject || \"\",\n      timestamp: item.json.date || \"\",\n\n      original: {\n        reviewText: item.json.text || \"\",\n        subject: item.json.subject || \"\",\n        timestamp: item.json.date || \"\"\n      }\n    }\n  };\n});"
      },
